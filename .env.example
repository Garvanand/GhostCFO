# GhostCFO Environment Variables
# Copy to .env and fill in your values

# -- App --
ENVIRONMENT=development
LOG_LEVEL=INFO
GHOSTCFO_PORT=8001
GHOSTCFO_TIMEZONE=Asia/Kolkata
GHOSTCFO_DAILY_BRIEFING_TIME=08:00

# -- Encryption --
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GHOSTCFO_ENCRYPTION_MASTER_KEY=

# -- Primary LLM (Anthropic) --
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6-20250219
ANTHROPIC_DAILY_BUDGET_USD=10.0

# -- Fallback LLM 1 (Groq) --
GROQ_API_KEY=
GROQ_LLM_MODEL=openai/gpt-oss-120b
GROQ_LLM_MODEL_FAST=llama-3.1-8b-instant

# -- Fallback LLM 2 (OpenRouter) --
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-pro
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# -- WhatsApp (shared with VaakShastra) --
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=ghostcfo_verify_2024

# -- VaakShastra AgentOS endpoint --
VAAKSHASTRA_BASE_URL=http://localhost:8000

# -- Gmail OAuth --
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=https://yourdomain.com/v1/oauth/gmail/callback

# -- Database & Cache (shared with Day01) --
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql+asyncpg://vaakshastra:vaakshastra@localhost:5432/vaakshastra

# -- GST API (future) --
GSTN_API_KEY=
